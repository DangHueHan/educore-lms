datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String?
  avatarUrl    String?
  role         String   @default("user")

  magicToken   String?  @unique
  magicExpires DateTime?
  lastLoginAt  DateTime?

  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Session[]
  enrollments  Enrollment[]
  quizResults  QuizResult[]
  progress     CourseProgress[]
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastActive DateTime @updatedAt

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String?

  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons     Lesson[]
  questions   Question[]

  enrollments Enrollment[]
  quizResults QuizResult[]
  progress    CourseProgress[]
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  videoUrl    String

  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Question {
  id          String   @id @default(cuid())
  courseId    String

  question    String
  explanation String?

  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  answers     Answer[]
  details     QuizResultDetail[]

  @@index([courseId])
}

model Answer {
  id          String   @id @default(cuid())
  questionId  String

  text        String
  isCorrect   Boolean  @default(false)

  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  selectedInDetails QuizResultDetail[]

  @@index([questionId])
}

model QuizResult {
  id              String   @id @default(cuid())
  userId          String
  courseId        String

  score           Int
  totalQuestions  Int
  correctAnswers  Int
  passed          Boolean

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User   @relation(fields: [userId], references: [id])
  course          Course @relation(fields: [courseId], references: [id])

  details         QuizResultDetail[]

  @@index([userId])
  @@index([courseId])
}

model QuizResultDetail {
  id               String @id @default(cuid())

  quizResultId     String
  questionId       String
  selectedAnswerId String?

  isCorrect        Boolean

  quizResult       QuizResult @relation(fields: [quizResultId], references: [id], onDelete: Cascade)
  question         Question    @relation(fields: [questionId], references: [id])
  answer           Answer?     @relation(fields: [selectedAnswerId], references: [id])

  @@index([quizResultId])
  @@index([questionId])
  @@index([selectedAnswerId])
}

model CourseProgress {
  id              String @id @default(cuid())
  userId          String
  courseId        String

  progressPercent Int @default(0)
  lastLessonIndex Int @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User   @relation(fields: [userId], references: [id])
  course          Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}