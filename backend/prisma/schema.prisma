datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  displayName String?
  avatarUrl   String?
  role        String  @default("user")

  magicToken   String?   @unique
  magicExpires DateTime?
  lastLoginAt  DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]
  quizResults QuizResult[]
  progress    CourseProgress[]

  lessonProgresses LessonProgress[]

  reviews CourseReview[]

  payments Payment[]
}

model Course {
  id          String  @id @default(cuid())
  title       String
  description String?
  thumbnail   String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessons   Lesson[]
  questions Question[]

  price Float @default(0)

  totalDurationSeconds Int @default(0)

  totalViews Int @default(0)

  reviews CourseReview[]

  payments Payment[]

  courseCoupons CourseCoupon[]

  enrollments Enrollment[]
  quizResults QuizResult[]
  progress    CourseProgress[]
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Lesson {
  id          String  @id @default(cuid())
  courseId    String
  title       String
  description String?
  videoUrl    String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  durationSeconds Int @default(0)

  progresses LessonProgress[]

  @@index([courseId])
}

model Question {
  id       String @id @default(cuid())
  courseId String

  question    String
  explanation String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  answers Answer[]
  details QuizResultDetail[]

  @@index([courseId])
}

model Answer {
  id         String @id @default(cuid())
  questionId String

  text      String
  isCorrect Boolean @default(false)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  selectedInDetails QuizResultDetail[]

  @@index([questionId])
}

model QuizResult {
  id       String @id @default(cuid())
  userId   String
  courseId String

  score          Int
  totalQuestions Int
  correctAnswers Int
  passed         Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  details QuizResultDetail[]

  @@index([userId])
  @@index([courseId])
}

model QuizResultDetail {
  id String @id @default(cuid())

  quizResultId     String
  questionId       String
  selectedAnswerId String?

  isCorrect Boolean

  quizResult QuizResult @relation(fields: [quizResultId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id])
  answer     Answer?    @relation(fields: [selectedAnswerId], references: [id])

  @@index([quizResultId])
  @@index([questionId])
  @@index([selectedAnswerId])
}

model CourseProgress {
  id       String @id @default(cuid())
  userId   String
  courseId String

  progressPercent Int @default(0)

  lastLessonId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id String @id @default(cuid())

  userId   String
  lessonId String

  watchedSeconds Int @default(0)

  isCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model CourseReview {
  id String @id @default(cuid())

  userId String

  courseId String

  rating Int

  comment String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Payment {
  id String @id @default(cuid())

  userId String
  courseId String

  originalAmount Float
  discountAmount Float @default(0)
  amount Float

  method String?

  status String

  transactionNo String?

  couponCode String?

  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  user User @relation(fields: [userId], references: [id])

  course Course @relation(fields: [courseId], references: [id])


  @@index([userId])
  @@index([courseId])
}



model Coupon {
  id String @id @default(cuid())

  code String @unique

  discountPercent Int

  quantity Int

  usedCount Int @default(0)

  isActive Boolean @default(true)


  startDate DateTime

  endDate DateTime

 isDeleted Boolean @default(false)

  deletedAt DateTime?
  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt


  courseCoupons CourseCoupon[]
}



model CourseCoupon {
  id String @id @default(cuid())


  courseId String

  couponId String


  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)


  @@unique([courseId, couponId])

  @@index([courseId])
  @@index([couponId])
}